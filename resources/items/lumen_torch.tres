[gd_resource type="Resource" script_class="ItemDef" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/core/items/item_def.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"lumen_torch"
display_name = "Lumen Torch"
max_stack = 20
category = &"placeable"
swatch_color = Color(1.0, 0.78, 0.2, 1)
description = "A crystal-core torch wound with lumen petals and spore-wax. Emits a steady warm-gold glow that repels the deep dark — and smells faintly of caramelized starfire."
