[resource]
script = ExtResource("1")
id = &"note_block"
display_name = "Note Block"
max_stack = 24
category = &"placeable"
swatch_color = Color(0.55, 0.2, 0.85, 1)
description = "A thumb-sized crystal that sings one pentatonic note when the Sequencer Core's beam sweeps past. Set it down, nudge it around the core, and watch where it lands in the loop — the angle is the rhythm."
