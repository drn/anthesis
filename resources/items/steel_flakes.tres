[resource]
script = ExtResource("1")
id = &"steel_flakes"
display_name = "Steel Flakes"
max_stack = 99
category = &"consumable"
swatch_color = Color(0.78, 0.82, 0.88, 1)
description = "Ground skysteel alloyed with trace lumen and ready to burn. The moment the powder ignites, every heavy mass becomes a launch ramp — an anchor to push against, a sky to throw yourself into."
