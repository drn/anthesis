[resource]
script = ExtResource("1")
id = &"skysteel_ore"
display_name = "Skysteel Ore"
max_stack = 64
category = &"material"
swatch_color = Color(0.72, 0.78, 0.85, 1)
description = "A dense silvery-grey ore mined from seams where starfall meteorites buried themselves aeons ago. Its alloy — steel alloyed with sky-iron — responds to Ferropush like a lover answering a call."
