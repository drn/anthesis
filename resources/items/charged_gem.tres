[gd_resource type="Resource" script_class="ItemDef" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/core/items/item_def.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"charged_gem"
display_name = "Charged Gem"
max_stack = 16
category = &"material"
swatch_color = Color(0.88, 0.84, 1.0, 1)
description = "A dun gem kissed by the Resonance Storm: the dull slate has gone luminous white-violet, the crystal lattice singing with captured lightning. Inhale its investiture and your veins ignite — wounds knit, the world bends sideways, and gravity becomes a suggestion."
